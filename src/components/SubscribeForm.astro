<section class="subscribe-card" aria-labelledby="subscribe-title">
  <div class="subscribe-copy">
    <p class="eyebrow">邮件提醒</p>
    <h2 id="subscribe-title">通过邮件接收更新提醒</h2>
    <p>
      你可以留下邮箱。以后本站有新文章发布时，会收到一封简短提醒邮件。
    </p>
    <p>
      我们只会用于发送本站更新提醒，不会用于其他用途。你也可以随时通过邮件底部链接退订。
    </p>
  </div>

  <form class="subscribe-form" data-subscribe-form>
    <label>
      <span>邮箱地址</span>
      <input
        type="email"
        name="email"
        autocomplete="email"
        inputmode="email"
        maxlength="254"
        placeholder="reader@example.com"
        required
      />
    </label>
    <label class="subscribe-honeypot" aria-hidden="true">
      <span>Website</span>
      <input type="text" name="website" tabindex="-1" autocomplete="off" />
    </label>
    <div class="subscribe-form-footer">
      <button type="submit">订阅更新提醒</button>
      <p class="subscribe-status" data-subscribe-status role="status" aria-live="polite"></p>
    </div>
  </form>
</section>

<style>
  .subscribe-card {
    display: grid;
    gap: 20px;
    max-width: 760px;
    margin: 34px auto 0;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: color-mix(in srgb, var(--color-card-solid) 30%, transparent);
    backdrop-filter: blur(18px);
    padding: clamp(22px, 4vw, 32px);
    text-align: left;
  }

  .subscribe-copy {
    display: grid;
    gap: 10px;
  }

  .subscribe-copy h2,
  .subscribe-copy p,
  .subscribe-status {
    margin: 0;
  }

  .subscribe-copy h2 {
    font-size: clamp(24px, 3vw, 34px);
  }

  .subscribe-form {
    display: grid;
    gap: 14px;
  }

  .subscribe-form label {
    display: grid;
    gap: 7px;
  }

  .subscribe-honeypot {
    display: none !important;
  }

  .subscribe-form-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
  }

  .subscribe-form button {
    min-height: 44px;
  }

  .subscribe-form button:disabled {
    cursor: wait;
    opacity: 0.7;
  }

  .subscribe-status {
    min-height: 1.4em;
    color: var(--color-text-3);
    font-size: 14px;
  }

  .subscribe-status[data-state="success"] {
    color: var(--color-text-2);
  }

  .subscribe-status[data-state="error"] {
    color: var(--color-gold);
  }

  @media (max-width: 760px) {
    .subscribe-form-footer {
      align-items: stretch;
      flex-direction: column;
    }
  }
</style>

<script>
  const form = document.querySelector("[data-subscribe-form]");
  const status = document.querySelector("[data-subscribe-status]");

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();

    if (!(form instanceof HTMLFormElement)) return;
    const submitButton = form.querySelector('button[type="submit"]');
    const formData = new FormData(form);
    const payload = {
      email: String(formData.get("email") || ""),
      website: String(formData.get("website") || "")
    };

    if (submitButton instanceof HTMLButtonElement) {
      submitButton.disabled = true;
    }

    if (status) {
      status.textContent = "正在提交…";
      status.removeAttribute("data-state");
    }

    try {
      const response = await fetch("/api/subscribe", {
        method: "POST",
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify(payload)
      });
      const result = await response.json();

      if (!response.ok || !result.ok) {
        throw new Error(result.message || "暂时无法完成订阅，请稍后再试。");
      }

      form.reset();
      if (status) {
        status.textContent = result.message || "如果邮箱地址有效，我们会发送一封确认邮件。请前往邮箱完成确认。";
        status.setAttribute("data-state", "success");
      }
    } catch (error) {
      if (status) {
        status.textContent = error instanceof Error ? error.message : "暂时无法完成订阅，请稍后再试。";
        status.setAttribute("data-state", "error");
      }
    } finally {
      if (submitButton instanceof HTMLButtonElement) {
        submitButton.disabled = false;
      }
    }
  });
</script>
