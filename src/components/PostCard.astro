---
interface Props {
  title: string;
  description: string;
  date: Date;
  publishedAt?: Date;
  href: string;
  tags?: string[];
  category?: string;
  featured?: boolean;
  readingTimeMinutes?: number;
}

const { title, description, date, publishedAt, href, tags = [], category = "", featured = false, readingTimeMinutes } = Astro.props;
const formattedDate = new Intl.DateTimeFormat("zh-CN", {
  year: "numeric",
  month: "2-digit",
  day: "2-digit"
}).format(date);
const postSlug = href.split("/").filter(Boolean).at(-1) ?? "";
const displayTags = Array.from(
  new Set([...tags.filter(Boolean), category].filter(Boolean))
);
---

<article
  id={`post-${postSlug}`}
  class:list={["post-card", { featured }]}
  data-category={category}
  data-post-slug={postSlug}
>
  <a href={href} class="post-card-link" data-post-link>
    <div class="post-card-meta">
      <time datetime={date.toISOString()}>{formattedDate}</time>
      <span class="meta-text" data-relative-time datetime={(publishedAt ?? date).toISOString()} hidden></span>
      {readingTimeMinutes && <span class="meta-text">阅读 {readingTimeMinutes} 分钟</span>}
      {featured && <span>最新</span>}
    </div>
    <h2>{title}</h2>
    <p>{description}</p>
    {
      displayTags.length > 0 && (
        <div class="tag-list" aria-label="文章标签">
          {displayTags.map((tag) => <span>{tag}</span>)}
        </div>
      )
    }
    <div class="post-card-stats" aria-label="文章阅读和留言次数">
      <span>阅读 <strong data-post-views={postSlug}>--</strong> 次</span>
      <span>留言 <strong data-post-comments={postSlug}>--</strong> 条</span>
    </div>
  </a>
</article>

<script>
  document.addEventListener("click", (event) => {
    const link = (event.target as Element | null)?.closest<HTMLAnchorElement>("[data-post-link]");
    if (!link) return;

    const card = link.closest<HTMLElement>("[data-post-slug]");
    const postSlug = card?.dataset.postSlug;
    if (!postSlug) return;

    const returnUrl = new URL(window.location.href);
    returnUrl.hash = `post-${postSlug}`;

    try {
      window.sessionStorage.setItem(`ronniecross-return-${postSlug}`, returnUrl.toString());
    } catch {
      // 定位功能仍可使用文章页提供的默认返回地址。
    }
  });
</script>
