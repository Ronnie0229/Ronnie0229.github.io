---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Logo from "../../components/Logo.astro";
import {
  NEW_TESTAMENT_BOOKS,
  OLD_TESTAMENT_BOOKS
} from "../../data/bible";
import { buildPostKnowledge } from "../../lib/knowledge";

const posts = await getCollection("posts", ({ data }) => !data.draft);
const bookCounts = new Map<string, number>();

for (const post of posts) {
  for (const book of buildPostKnowledge(post).bibleBooks) {
    bookCounts.set(book, (bookCounts.get(book) ?? 0) + 1);
  }
}

const getBooksWithCounts = (books: readonly string[]) =>
  books.map((book) => ({
    name: book,
    count: bookCounts.get(book) ?? 0
  }));

const testamentSections = [
  {
    title: "旧约",
    books: getBooksWithCounts(OLD_TESTAMENT_BOOKS)
  },
  {
    title: "新约",
    books: getBooksWithCounts(NEW_TESTAMENT_BOOKS)
  }
];

const totalBooksWithPosts = [...bookCounts.values()].filter((count) => count > 0).length;
const totalBookLinks = OLD_TESTAMENT_BOOKS.length + NEW_TESTAMENT_BOOKS.length;
---

<BaseLayout title="圣经书卷 | Ronnie" description="按圣经书卷浏览 Ronnie 已发布的文章。">
  <section class="page-heading bible-heading">
    <Logo size="md" showText={false} class="page-brand-mark" />
    <p class="eyebrow">圣经书卷</p>
    <h1>按书卷阅读文章</h1>
    <p>这里按旧约和新约整理已经发布的文章。有文章的书卷可以直接进入对应页面，暂无文章的书卷会保留在目录中，方便以后补充。</p>
    <div class="bible-overview-stats" aria-label="圣经文章统计">
      <span>{posts.length} 篇文章</span>
      <span>{totalBooksWithPosts} / {totalBookLinks} 卷已有文章</span>
    </div>
  </section>

  <div class="bible-sections">
    {
      testamentSections.map((section) => (
        <section class="bible-section" aria-labelledby={`${section.title}-heading`}>
          <div class="bible-section-heading">
            <div>
              <p class="eyebrow">圣经</p>
              <h2 id={`${section.title}-heading`}>{section.title}</h2>
            </div>
            <span>{section.books.filter((book) => book.count > 0).length} 卷已有文章</span>
          </div>
          <div class="book-grid">
            {section.books.map((book) =>
              book.count > 0 ? (
                <a class="book-link has-posts" href={`/bible/${book.name}/`}>
                  <strong>{book.name}</strong>
                  <span>{book.count} 篇文章</span>
                </a>
              ) : (
                <div class="book-link is-empty" aria-disabled="true">
                  <strong>{book.name}</strong>
                  <span>暂无文章</span>
                </div>
              )
            )}
          </div>
        </section>
      ))
    }
  </div>
</BaseLayout>
