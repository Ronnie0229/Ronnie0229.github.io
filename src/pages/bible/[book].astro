---
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Logo from "../../components/Logo.astro";
import { BIBLE_BOOKS } from "../../data/bible";
import { buildPostKnowledge } from "../../lib/knowledge";

interface Props {
  book: string;
  posts: CollectionEntry<"posts">[];
}

function getBookReferenceSortKey(post: CollectionEntry<"posts">, book: string) {
  const references = buildPostKnowledge(post).scriptureKnowledge.references
    .filter((reference) => reference.book === book)
    .sort(
      (a, b) =>
        (a.chapterStart ?? Number.POSITIVE_INFINITY) - (b.chapterStart ?? Number.POSITIVE_INFINITY) ||
        (a.verseStart ?? Number.POSITIVE_INFINITY) - (b.verseStart ?? Number.POSITIVE_INFINITY)
    );
  const reference = references[0];

  return {
    chapter: reference?.chapterStart ?? Number.POSITIVE_INFINITY,
    verse: reference?.verseStart ?? Number.POSITIVE_INFINITY
  };
}

export async function getStaticPaths() {
  const posts = (await getCollection("posts", ({ data }) => !data.draft)).sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
  );
  const getReferenceKey = (post: CollectionEntry<"posts">, book: string) => {
    const references = buildPostKnowledge(post).scriptureKnowledge.references
      .filter((reference) => reference.book === book)
      .sort(
        (a, b) =>
          (a.chapterStart ?? Number.POSITIVE_INFINITY) - (b.chapterStart ?? Number.POSITIVE_INFINITY) ||
          (a.verseStart ?? Number.POSITIVE_INFINITY) - (b.verseStart ?? Number.POSITIVE_INFINITY)
      );
    const reference = references[0];

    return {
      chapter: reference?.chapterStart ?? Number.POSITIVE_INFINITY,
      verse: reference?.verseStart ?? Number.POSITIVE_INFINITY
    };
  };

  return BIBLE_BOOKS.map((book) => ({
    book,
    posts: posts
      .filter((post) => buildPostKnowledge(post).bibleBooks.includes(book))
      .sort((a, b) => {
        const aKey = getReferenceKey(a, book);
        const bKey = getReferenceKey(b, book);

        return (
          aKey.chapter - bKey.chapter ||
          aKey.verse - bKey.verse ||
          b.data.date.valueOf() - a.data.date.valueOf()
        );
      })
  }))
    .filter(({ posts }) => posts.length > 0)
    .map(({ book, posts }) => ({
      params: { book },
      props: { book, posts }
    }));
}

const { book, posts } = Astro.props;
const postItems = posts.map((post) => ({
  post,
  knowledge: buildPostKnowledge(post)
}));
const topicCounts = new Map<string, number>();

for (const item of postItems) {
  for (const topic of item.knowledge.topics) {
    topicCounts.set(topic, (topicCounts.get(topic) ?? 0) + 1);
  }
}

const featuredTopics = [...topicCounts.entries()]
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0], "zh-CN"))
  .slice(0, 6)
  .map(([topic]) => topic);
const totalReadingMinutes = postItems.reduce(
  (total, item) => total + item.knowledge.readingTimeMinutes,
  0
);
---

<BaseLayout title={`${book} | 圣经书卷 | Ronnie`} description={`浏览 ${book} 相关的 Ronnie 已发布文章。`}>
  <section class="page-heading bible-book-heading">
    <Logo size="md" showText={false} class="page-brand-mark page-brand-mark-small" />
    <p class="eyebrow"><a href="/bible/">圣经书卷</a></p>
    <h1>{book}</h1>
    <p>共 {posts.length} 篇相关文章。默认按圣经章节顺序排列，也可以切换为按发布时间排列。</p>
    <div class="bible-overview-stats" aria-label={`${book}文章统计`}>
      <span>{posts.length} 篇文章</span>
      <span>阅读约 {totalReadingMinutes} 分钟</span>
      {featuredTopics.length > 0 && <span>{featuredTopics.length} 个常见主题</span>}
    </div>
  </section>

  {
    featuredTopics.length > 0 && (
      <section class="bible-section bible-topic-summary" aria-labelledby="book-topic-heading">
        <div class="bible-section-heading">
          <div>
            <p class="eyebrow">Topics</p>
            <h2 id="book-topic-heading">相关主题</h2>
          </div>
          <span>从本卷文章中自动整理</span>
        </div>
        <div class="search-result-details">
          {featuredTopics.map((topic) => <span>{topic}</span>)}
        </div>
      </section>
    )
  }

  <div class="bible-sort-controls" aria-label={`${book}文章排序方式`}>
    <span>排序：</span>
    <div class="bible-sort-buttons" role="group" aria-label="选择排序方式">
      <button type="button" class="active" data-sort-mode="chapter" aria-pressed="true">章节顺</button>
      <button type="button" data-sort-mode="published" aria-pressed="false">发布顺</button>
    </div>
  </div>
  <nav class="pagination bible-pagination bible-pagination-top" aria-label={`${book}文章顶部分页`}></nav>
  <section class="post-list bible-post-list" aria-label={`${book}文章列表`}>
    {
      postItems.map(({ post, knowledge }) => {
        const postSlug = post.slug;
        const formattedDate = new Intl.DateTimeFormat("zh-CN", {
          year: "numeric",
          month: "2-digit",
          day: "2-digit"
        }).format(post.data.date);
        const badges = [...knowledge.topics.slice(0, 3), ...post.data.tags.slice(0, 2)];
        const referenceKey = getBookReferenceSortKey(post, book);

        return (
          <article
            id={`post-${postSlug}`}
            class="post-card bible-post-card"
            data-post-slug={postSlug}
            data-chapter={Number.isFinite(referenceKey.chapter) ? referenceKey.chapter : ""}
            data-verse={Number.isFinite(referenceKey.verse) ? referenceKey.verse : ""}
            data-published={post.data.date.valueOf()}
          >
            <a href={`/posts/${postSlug}/`} class="post-card-link bible-post-card-link" data-post-link>
              <div class="post-card-meta bible-post-meta">
                <time datetime={post.data.date.toISOString()}>{formattedDate}</time>
                <span class="meta-text" data-relative-time datetime={post.data.date.toISOString()} hidden></span>
                <span class="meta-text">阅读 {knowledge.readingTimeMinutes} 分钟</span>
              </div>
              <h2>{post.data.title}</h2>
              <p>{knowledge.description}</p>
              {badges.length > 0 && (
                <div class="tag-list bible-post-tags" aria-label="文章主题和标签">
                  {badges.map((badge) => <span>{badge}</span>)}
                </div>
              )}
            </a>
          </article>
        );
      })
    }
  </section>
  <nav class="pagination bible-pagination bible-pagination-bottom" aria-label={`${book}文章底部分页`}></nav>

  <script>
    const pageSize = 20;
    const postList = document.querySelector<HTMLElement>(".bible-post-list");
    let cards = Array.from(
      document.querySelectorAll<HTMLElement>(".bible-post-list > .bible-post-card")
    );
    const paginations = Array.from(document.querySelectorAll<HTMLElement>(".bible-pagination"));
    const sortButtons = Array.from(
      document.querySelectorAll<HTMLButtonElement>("[data-sort-mode]")
    );

    const readSortNumber = (card: HTMLElement, key: "chapter" | "verse" | "published") => {
      const value = Number(card.dataset[key]);
      return Number.isFinite(value) && card.dataset[key] !== "" ? value : Number.POSITIVE_INFINITY;
    };

    const sortCards = (mode: "chapter" | "published") => {
      cards.sort((a, b) => {
        if (mode === "published") {
          return readSortNumber(b, "published") - readSortNumber(a, "published");
        }

        return (
          readSortNumber(a, "chapter") - readSortNumber(b, "chapter") ||
          readSortNumber(a, "verse") - readSortNumber(b, "verse") ||
          readSortNumber(b, "published") - readSortNumber(a, "published")
        );
      });

      if (postList) cards.forEach((card) => postList.append(card));
      sortButtons.forEach((button) => {
        const active = button.dataset.sortMode === mode;
        button.classList.toggle("active", active);
        button.setAttribute("aria-pressed", String(active));
      });
    };

    const getPaginationItems = (current: number, total: number) => {
      const items = new Set([1, total, current - 1, current, current + 1]);

      if (current <= 4) {
        [2, 3, 4, 5].forEach((page) => items.add(page));
      }
      if (current >= total - 3) {
        [total - 4, total - 3, total - 2, total - 1].forEach((page) => items.add(page));
      }

      const pages = [...items]
        .filter((page) => page >= 1 && page <= total)
        .sort((a, b) => a - b);
      const result: Array<number | "ellipsis"> = [];

      pages.forEach((page, index) => {
        const previous = pages[index - 1];
        if (previous && page - previous > 1) result.push("ellipsis");
        result.push(page);
      });

      return result;
    };

    const showPage = (requestedPage: number) => {
      const pageCount = Math.max(1, Math.ceil(cards.length / pageSize));
      const currentPage = Math.min(Math.max(requestedPage, 1), pageCount);
      const firstIndex = (currentPage - 1) * pageSize;

      cards.forEach((card, index) => {
        card.hidden = index < firstIndex || index >= firstIndex + pageSize;
      });

      paginations.forEach((pagination) => {
        pagination.replaceChildren();
        if (pageCount > 1) {
          const addButton = (label: string, page: number, active = false, disabled = false) => {
            const button = document.createElement("button");
            button.type = "button";
            button.textContent = label;
            button.classList.toggle("active", active);
            button.disabled = disabled;
            button.setAttribute("aria-label", label);
            if (active) button.setAttribute("aria-current", "page");
            button.addEventListener("click", () => updatePage(page));
            pagination.append(button);
          };

          addButton("上一页", currentPage - 1, false, currentPage === 1);
          getPaginationItems(currentPage, pageCount).forEach((item) => {
            if (item === "ellipsis") {
              const ellipsis = document.createElement("span");
              ellipsis.className = "pagination-ellipsis";
              ellipsis.textContent = "...";
              ellipsis.setAttribute("aria-hidden", "true");
              pagination.append(ellipsis);
              return;
            }
            addButton(String(item), item, item === currentPage);
          });
          addButton("下一页", currentPage + 1, false, currentPage === pageCount);
        }
      });

      return currentPage;
    };

    const updatePage = (page: number) => {
      showPage(page);
      document.querySelector(".bible-sort-controls")?.scrollIntoView({ behavior: "smooth", block: "start" });
    };

    sortButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const mode = button.dataset.sortMode === "published" ? "published" : "chapter";
        sortCards(mode);
        showPage(1);
        document.querySelector(".bible-sort-controls")?.scrollIntoView({ behavior: "smooth", block: "start" });
      });
    });

    document.addEventListener("click", (event) => {
      const link = (event.target as Element | null)?.closest<HTMLAnchorElement>("[data-post-link]");
      if (!link) return;

      const card = link.closest<HTMLElement>("[data-post-slug]");
      const postSlug = card?.dataset.postSlug;
      if (!postSlug) return;

      const returnUrl = new URL(window.location.href);
      returnUrl.search = "";
      returnUrl.hash = `post-${postSlug}`;

      try {
        window.sessionStorage.setItem(`ronniecross-return-${postSlug}`, returnUrl.toString());
      } catch {
        // The article still opens normally if sessionStorage is unavailable.
      }
    });

    const readHashFocusedSlug = () => {
      if (!window.location.hash.startsWith("#post-")) return "";

      try {
        return decodeURIComponent(window.location.hash.slice("#post-".length));
      } catch {
        return window.location.hash.slice("#post-".length);
      }
    };

    const params = new URLSearchParams(window.location.search);
    const initialPage = Number.parseInt(params.get("page") || "1", 10);
    const focusedSlug = readHashFocusedSlug() || params.get("focus") || "";
    const focusedCard = focusedSlug
      ? cards.find((card) => card.dataset.postSlug === focusedSlug)
      : undefined;
    const focusedIndex = focusedCard ? cards.indexOf(focusedCard) : -1;
    const focusedPage = focusedIndex >= 0 ? Math.floor(focusedIndex / pageSize) + 1 : null;

    showPage(focusedPage ?? (Number.isFinite(initialPage) ? initialPage : 1));

    if (window.location.search) {
      const cleanUrl = `${window.location.pathname}${focusedCard ? `#post-${focusedCard.dataset.postSlug}` : window.location.hash}`;
      window.history.replaceState({}, "", cleanUrl);
    }

    if (focusedCard && !focusedCard.hidden) {
      window.requestAnimationFrame(() => {
        focusedCard.scrollIntoView({ behavior: "smooth", block: "center" });
        focusedCard.classList.add("post-card-focused");
        window.setTimeout(() => focusedCard.classList.remove("post-card-focused"), 1800);
      });
    }
  </script>
</BaseLayout>
