---
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Logo from "../../components/Logo.astro";
import PostCard from "../../components/PostCard.astro";
import { BIBLE_BOOKS } from "../../data/bible";
import { buildPostKnowledge } from "../../lib/knowledge";

interface Props {
  book: string;
  posts: CollectionEntry<"posts">[];
}

export async function getStaticPaths() {
  const posts = (await getCollection("posts", ({ data }) => !data.draft)).sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
  );

  return BIBLE_BOOKS.map((book) => ({
    book,
    posts: posts.filter((post) => buildPostKnowledge(post).bibleBooks.includes(book))
  }))
    .filter(({ posts }) => posts.length > 0)
    .map(({ book, posts }) => ({
      params: { book },
      props: { book, posts }
    }));
}

const { book, posts } = Astro.props;
---

<BaseLayout title={`${book} | 圣经书卷 | Ronnie`} description={`浏览与${book}有关的已发布文章。`}>
  <section class="page-heading bible-book-heading">
    <Logo size="md" showText={false} class="page-brand-mark page-brand-mark-small" />
    <p class="eyebrow"><a href="/bible/">圣经书卷</a></p>
    <h1>{book}</h1>
    <p>共 {posts.length} 篇相关文章，按发布时间从新到旧排列。</p>
  </section>

  <section class="post-list bible-post-list" aria-label={`${book}文章列表`}>
    {
      posts.map((post) => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          date={post.data.date}
          href={`/posts/${post.slug}/`}
          tags={post.data.tags}
          category={post.data.category}
        />
      ))
    }
  </section>
  <nav class="pagination bible-pagination" aria-label={`${book}文章分页`}></nav>

  <script>
    const pageSize = 20;
    const cards = Array.from(
      document.querySelectorAll<HTMLElement>(".bible-post-list > .post-card")
    );
    const pagination = document.querySelector<HTMLElement>(".bible-pagination");

    const showPage = (requestedPage: number) => {
      const pageCount = Math.max(1, Math.ceil(cards.length / pageSize));
      const currentPage = Math.min(Math.max(requestedPage, 1), pageCount);
      const firstIndex = (currentPage - 1) * pageSize;

      cards.forEach((card, index) => {
        card.hidden = index < firstIndex || index >= firstIndex + pageSize;
      });

      if (pagination) {
        pagination.replaceChildren();
        if (pageCount > 1) {
          const addButton = (label: string, page: number, active = false, disabled = false) => {
            const button = document.createElement("button");
            button.type = "button";
            button.textContent = label;
            button.classList.toggle("active", active);
            button.disabled = disabled;
            button.setAttribute("aria-label", label);
            button.addEventListener("click", () => updatePage(page));
            pagination.append(button);
          };

          addButton("上一页", currentPage - 1, false, currentPage === 1);
          for (let page = 1; page <= pageCount; page += 1) {
            addButton(String(page), page, page === currentPage);
          }
          addButton("下一页", currentPage + 1, false, currentPage === pageCount);
        }
      }

      return currentPage;
    };

    const updatePage = (page: number) => {
      const currentPage = showPage(page);
      const url = new URL(window.location.href);
      if (currentPage === 1) {
        url.searchParams.delete("page");
      } else {
        url.searchParams.set("page", String(currentPage));
      }
      window.history.replaceState({}, "", url);
      document.querySelector(".bible-book-heading")?.scrollIntoView({ behavior: "smooth" });
    };

    const params = new URLSearchParams(window.location.search);
    const initialPage = Number.parseInt(params.get("page") || "1", 10);
    const focusedSlug = params.get("focus");
    const focusedCard = focusedSlug
      ? cards.find((card) => card.dataset.postSlug === focusedSlug)
      : undefined;
    const focusedIndex = focusedCard ? cards.indexOf(focusedCard) : -1;
    const focusedPage = focusedIndex >= 0 ? Math.floor(focusedIndex / pageSize) + 1 : null;

    showPage(focusedPage ?? (Number.isFinite(initialPage) ? initialPage : 1));

    if (focusedCard && !focusedCard.hidden) {
      window.requestAnimationFrame(() => {
        focusedCard.scrollIntoView({ behavior: "smooth", block: "center" });
        focusedCard.classList.add("post-card-focused");
        window.setTimeout(() => focusedCard.classList.remove("post-card-focused"), 1800);
      });
    }
  </script>
</BaseLayout>
