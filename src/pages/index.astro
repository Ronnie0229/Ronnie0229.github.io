---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";

const posts = (await getCollection("posts")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const latestPost = posts[0];
const otherPosts = posts.slice(1, 4);
---

<BaseLayout title="Ronnie | 讲道文章主页" description="Ronnie 的个人主页，整理和发布中文讲道文章。">
  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">Latest writing</p>
      <h1>把听到的，看到的，学到的，整理成可以安静阅读的文字。</h1>
      <p class="hero-text">
        这里是 Ronnie 的个人文章主页。讲道内容已经按时间整理为 Markdown，最新内容会优先显示，方便阅读和后续继续发布。
      </p>
    </div>
    {
      latestPost && (
        <PostCard
          title={latestPost.data.title}
          description={latestPost.data.description}
          date={latestPost.data.date}
          href={`/posts/${latestPost.slug}/`}
          tags={latestPost.data.tags}
          category={latestPost.data.category}
          featured
        />
      )
    }
  </section>

  <section class="section-header">
    <div>
      <p class="eyebrow">Archive</p>
      <h2>最新文章</h2>
    </div>
    <a class="text-link" href="/posts/">查看全部</a>
  </section>

  <section class="post-grid" aria-label="最新文章列表">
    {
      otherPosts.map((post) => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          date={post.data.date}
          href={`/posts/${post.slug}/`}
          tags={post.data.tags}
          category={post.data.category}
        />
      ))
    }
  </section>

  <section id="about" class="about-panel">
    <p class="eyebrow">About Ronnie</p>
    <h2>这是一个整理讲道文章的空间。</h2>
    <p>
      原始资料保留在本地目录中，网站发布使用整理后的 Markdown 文件。后续新增讲道内容时，可以继续运行导入脚本生成新的文章。
    </p>
  </section>
</BaseLayout>
