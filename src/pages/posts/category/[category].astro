---
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Logo from "../../../components/Logo.astro";
import PostCard from "../../../components/PostCard.astro";
import { buildPostKnowledge } from "../../../lib/knowledge";
import { CATEGORY_ROUTE_LIST, type CategorySlug } from "../../../lib/categories";

export async function getStaticPaths() {
  const posts = await getCollection("posts", ({ data }) => !data.draft);

  return CATEGORY_ROUTE_LIST.map((route) => ({
    params: { category: route.slug },
    props: {
      route,
      posts: posts
        .filter((post) => post.data.category === route.category)
        .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
    }
  }));
}

const { route, posts } = Astro.props as {
  route: (typeof CATEGORY_ROUTE_LIST)[number] & { slug: CategorySlug };
  posts: Awaited<ReturnType<typeof getCollection<"posts">>>;
};
---

<BaseLayout title={route.title} description={route.description}>
  <section class="page-heading posts-heading">
    <Logo size="md" showText={false} class="page-brand-mark" />
    <p class="eyebrow">{route.eyebrow}</p>
    <h1>{route.heading}</h1>
    <p>{route.description}</p>
  </section>

  <nav class="pagination pagination-top" aria-label={`${route.label}文章顶部分页`}></nav>
  <section class="post-list" aria-label={`${route.label}文章列表`}>
    {
      posts.map((post) => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          date={post.data.date}
          href={`/posts/${post.slug}/`}
          tags={post.data.tags}
          category={post.data.category}
          readingTimeMinutes={buildPostKnowledge(post).readingTimeMinutes}
        />
      ))
    }
  </section>
  <nav class="pagination pagination-bottom" aria-label={`${route.label}文章底部分页`}></nav>

  <script>
    const pageSize = 20;
    const cards = Array.from(document.querySelectorAll<HTMLElement>("[data-post-slug]"));
    const paginations = Array.from(document.querySelectorAll<HTMLElement>(".pagination"));

    const getPaginationItems = (current: number, total: number) => {
      const items = new Set([1, total, current - 1, current, current + 1]);

      if (current <= 4) {
        [2, 3, 4, 5].forEach((page) => items.add(page));
      }
      if (current >= total - 3) {
        [total - 4, total - 3, total - 2, total - 1].forEach((page) => items.add(page));
      }

      const pages = [...items]
        .filter((page) => page >= 1 && page <= total)
        .sort((a, b) => a - b);
      const result: Array<number | "ellipsis"> = [];

      pages.forEach((page, index) => {
        const previous = pages[index - 1];
        if (previous && page - previous > 1) result.push("ellipsis");
        result.push(page);
      });

      return result;
    };

    const showPage = (requestedPage = 1) => {
      const pageCount = Math.max(1, Math.ceil(cards.length / pageSize));
      const currentPage = Math.min(Math.max(requestedPage, 1), pageCount);
      const firstIndex = (currentPage - 1) * pageSize;
      const visibleCards = new Set(cards.slice(firstIndex, firstIndex + pageSize));

      cards.forEach((card) => {
        card.hidden = !visibleCards.has(card);
      });

      paginations.forEach((pagination) => {
        pagination.replaceChildren();
        if (pageCount > 1) {
          const addButton = (label: string, page: number, active = false, disabled = false) => {
            const button = document.createElement("button");
            button.type = "button";
            button.textContent = label;
            button.classList.toggle("active", active);
            button.disabled = disabled;
            button.setAttribute("aria-label", label);
            if (active) button.setAttribute("aria-current", "page");
            button.addEventListener("click", () => {
              showPage(page);
              document.querySelector(".posts-heading")?.scrollIntoView({ behavior: "smooth" });
            });
            pagination.append(button);
          };

          addButton("上一页", currentPage - 1, false, currentPage === 1);
          getPaginationItems(currentPage, pageCount).forEach((item) => {
            if (item === "ellipsis") {
              const ellipsis = document.createElement("span");
              ellipsis.className = "pagination-ellipsis";
              ellipsis.textContent = "...";
              ellipsis.setAttribute("aria-hidden", "true");
              pagination.append(ellipsis);
              return;
            }
            addButton(String(item), item, item === currentPage);
          });
          addButton("下一页", currentPage + 1, false, currentPage === pageCount);
        }
      });
    };

    showPage();
  </script>
</BaseLayout>
