---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";

const posts = (await getCollection("posts", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BaseLayout title="全部文章 | Ronnie" description="Ronnie 的全部文章列表。">
  <section class="page-heading posts-heading">
    <img
      class="page-brand-mark"
      src="/images/ronniecross-mark.png"
      alt=""
      width="48"
      height="49"
      aria-hidden="true"
    />
    <p class="eyebrow" data-category-eyebrow>全部文章</p>
    <h1 data-category-title>文章总览</h1>
    <p data-category-description>汇集所有已发布的文章，按发布时间从新到旧排列。</p>
  </section>

  <section class="post-list" aria-label="全部文章列表">
    {
      posts.map((post) => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          date={post.data.date}
          href={`/posts/${post.slug}/`}
          tags={post.data.tags}
          category={post.data.category}
        />
      ))
    }
  </section>
  <nav class="pagination" aria-label="文章分页"></nav>

  <script>
    const pageSize = 20;
    const cards = document.querySelectorAll<HTMLElement>("[data-category]");
    const pagination = document.querySelector<HTMLElement>(".pagination");
    const availableFilters = new Set(Array.from(cards, (card) => card.dataset.category));
    const headingEyebrow = document.querySelector<HTMLElement>("[data-category-eyebrow]");
    const headingTitle = document.querySelector<HTMLElement>("[data-category-title]");
    const headingDescription = document.querySelector<HTMLElement>("[data-category-description]");
    const categoryHeadings = {
      全部: {
        eyebrow: "全部文章",
        title: "文章总览",
        description: "汇集所有已发布的文章，按发布时间从新到旧排列。"
      },
      教会讲道: {
        eyebrow: "教会讲道",
        title: "聆听与研读",
        description: "收录明确归类为教会讲道的内容，整理经文信息，方便安静阅读与回顾。"
      },
      灵命成长: {
        eyebrow: "灵命成长",
        title: "信仰与生活",
        description: "收录个人分享、见证与信仰生活的整理，在日常经历中学习并活出真理。"
      }
    } as const;

    const applyFilter = (filter: string, requestedPage = 1) => {
      const selectedFilter = availableFilters.has(filter) ? filter : "全部";
      const heading =
        categoryHeadings[selectedFilter as keyof typeof categoryHeadings] ?? categoryHeadings.全部;
      const filteredCards = Array.from(cards).filter(
        (card) => selectedFilter === "全部" || card.dataset.category === selectedFilter
      );
      const pageCount = Math.max(1, Math.ceil(filteredCards.length / pageSize));
      const currentPage = Math.min(Math.max(requestedPage, 1), pageCount);
      const firstIndex = (currentPage - 1) * pageSize;
      const visibleCards = new Set(filteredCards.slice(firstIndex, firstIndex + pageSize));

      cards.forEach((card) => {
        card.hidden = !visibleCards.has(card);
      });

      if (headingEyebrow) headingEyebrow.textContent = heading.eyebrow;
      if (headingTitle) headingTitle.textContent = heading.title;
      if (headingDescription) headingDescription.textContent = heading.description;
      document.title = `${heading.eyebrow} | Ronnie`;

      if (pagination) {
        pagination.replaceChildren();
        if (pageCount > 1) {
          const addButton = (label: string, page: number, active = false, disabled = false) => {
            const button = document.createElement("button");
            button.type = "button";
            button.textContent = label;
            button.classList.toggle("active", active);
            button.disabled = disabled;
            button.setAttribute("aria-label", label);
            button.addEventListener("click", () => updateView(selectedFilter, page));
            pagination.append(button);
          };

          addButton("上一页", currentPage - 1, false, currentPage === 1);
          for (let page = 1; page <= pageCount; page += 1) {
            addButton(String(page), page, page === currentPage);
          }
          addButton("下一页", currentPage + 1, false, currentPage === pageCount);
        }
      }

      return { selectedFilter, currentPage };
    };

    const updateView = (filter: string, page: number) => {
      const state = applyFilter(filter, page);
      const url = new URL(window.location.href);
      if (state.selectedFilter === "全部") {
        url.searchParams.delete("category");
      } else {
        url.searchParams.set("category", state.selectedFilter);
      }
      if (state.currentPage === 1) {
        url.searchParams.delete("page");
      } else {
        url.searchParams.set("page", String(state.currentPage));
      }
      window.history.replaceState({}, "", url);
      document.querySelector(".posts-heading")?.scrollIntoView({ behavior: "smooth" });
    };

    const params = new URLSearchParams(window.location.search);
    const initialFilter = params.get("category") || "全部";
    const initialPage = Number.parseInt(params.get("page") || "1", 10);
    const focusedSlug = params.get("focus");
    const selectedFilter = availableFilters.has(initialFilter) ? initialFilter : "全部";
    const focusedCard = focusedSlug
      ? Array.from(cards).find((card) => card.dataset.postSlug === focusedSlug)
      : undefined;
    const filteredCards = Array.from(cards).filter(
      (card) => selectedFilter === "全部" || card.dataset.category === selectedFilter
    );
    const focusedIndex = focusedCard ? filteredCards.indexOf(focusedCard) : -1;
    const focusedPage = focusedIndex >= 0 ? Math.floor(focusedIndex / pageSize) + 1 : null;

    applyFilter(
      initialFilter,
      focusedPage ?? (Number.isFinite(initialPage) ? initialPage : 1)
    );

    if (focusedCard && !focusedCard.hidden) {
      window.requestAnimationFrame(() => {
        focusedCard.scrollIntoView({ behavior: "smooth", block: "center" });
        focusedCard.classList.add("post-card-focused");
        window.setTimeout(() => focusedCard.classList.remove("post-card-focused"), 1800);
      });
    }
  </script>
</BaseLayout>
