---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";

const posts = (await getCollection("posts")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const categories = [...new Set(posts.map((post) => post.data.category))].sort();
---

<BaseLayout title="全部讲道文章 | Ronnie" description="Ronnie 的全部讲道文章列表。">
  <section class="page-heading">
    <p class="eyebrow">All posts</p>
    <h1>全部讲道文章</h1>
    <p>这里按发布时间展示整理后的中文讲道文章，最新内容排在最前面。</p>
  </section>

  <div class="category-filter" aria-label="文章分类筛选">
    <button class="active" type="button" data-filter="全部">全部</button>
    {categories.map((category) => <button type="button" data-filter={category}>{category}</button>)}
  </div>

  <section class="post-list" aria-label="全部文章列表">
    {
      posts.map((post) => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          date={post.data.date}
          href={`/posts/${post.slug}/`}
          tags={post.data.tags}
          category={post.data.category}
        />
      ))
    }
  </section>

  <script>
    const buttons = document.querySelectorAll<HTMLButtonElement>("[data-filter]");
    const cards = document.querySelectorAll<HTMLElement>("[data-category]");
    const availableFilters = new Set(
      Array.from(buttons, (button) => button.dataset.filter).filter(Boolean)
    );

    const applyFilter = (filter: string) => {
      const selectedFilter = availableFilters.has(filter) ? filter : "全部";
      buttons.forEach((button) => {
        button.classList.toggle("active", button.dataset.filter === selectedFilter);
      });
      cards.forEach((card) => {
        card.hidden = selectedFilter !== "全部" && card.dataset.category !== selectedFilter;
      });
    };

    const initialFilter = new URLSearchParams(window.location.search).get("category") || "全部";
    applyFilter(initialFilter);

    buttons.forEach((button) => {
      button.addEventListener("click", () => {
        const filter = button.dataset.filter || "全部";
        applyFilter(filter);
        const url = new URL(window.location.href);
        if (filter === "全部") {
          url.searchParams.delete("category");
        } else {
          url.searchParams.set("category", filter);
        }
        window.history.replaceState({}, "", url);
      });
    });
  </script>
</BaseLayout>
