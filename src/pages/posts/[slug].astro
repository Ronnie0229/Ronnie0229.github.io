---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Comments from "../../components/Comments.astro";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post }
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const formattedDate = new Intl.DateTimeFormat("zh-CN", {
  year: "numeric",
  month: "2-digit",
  day: "2-digit"
}).format(post.data.date);
const fallbackReturnUrl = `/posts/?category=${encodeURIComponent(post.data.category)}&focus=${encodeURIComponent(post.slug)}#post-${post.slug}`;
---

<BaseLayout title={`${post.data.title} | Ronnie`} description={post.data.description}>
  <article class="article-page">
    <a
      class="text-link"
      href={fallbackReturnUrl}
      data-return-to-post={post.slug}
    >
      返回文章列表
    </a>
    <header class="article-header">
      <p class="eyebrow">{formattedDate}</p>
      <h1>{post.data.title}</h1>
      <p class="article-view-count">
        阅读 <span data-post-views={post.slug} data-increment-view>--</span> 次
      </p>
      <p>{post.data.description}</p>
      <div class="tag-list">
        {post.data.tags.map((tag) => <span>{tag}</span>)}
      </div>
    </header>
    <div class="article-content">
      <Content />
    </div>
    <a
      class="text-link article-return-link"
      href={fallbackReturnUrl}
      data-return-to-post={post.slug}
    >
      返回文章列表
    </a>
    <Comments postSlug={post.slug} />
  </article>

  <script>
    const returnLinks = document.querySelectorAll<HTMLAnchorElement>("[data-return-to-post]");
    const postSlug = returnLinks[0]?.dataset.returnToPost;

    if (returnLinks.length && postSlug) {
      try {
        const savedReturnUrl = window.sessionStorage.getItem(`ronniecross-return-${postSlug}`);
        if (savedReturnUrl) {
          const url = new URL(savedReturnUrl);
          if (url.origin === window.location.origin) {
            returnLinks.forEach((link) => {
              link.href = `${url.pathname}${url.search}${url.hash}`;
            });
          }
        }
      } catch {
        // 使用服务端生成的默认文章列表地址。
      }
    }
  </script>
</BaseLayout>
