---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Comments from "../../components/Comments.astro";
import { buildPostKnowledge, getRelatedPosts } from "../../lib/knowledge";
import { getCategoryRouteByCategory } from "../../lib/categories";

export async function getStaticPaths() {
  const posts = (await getCollection("posts", ({ data }) => !data.draft)).sort(
    (a, b) =>
      a.data.date.valueOf() - b.data.date.valueOf() ||
      a.data.title.localeCompare(b.data.title, "zh-CN")
  );
  return posts.map((post, index) => ({
    params: { slug: post.slug },
    props: {
      post,
      previousPost: posts[index - 1] || null,
      nextPost: posts[index + 1] || null,
      relatedPosts: getRelatedPosts(post, posts, 3)
    }
  }));
}

const { post, previousPost, nextPost, relatedPosts } = Astro.props;
const knowledge = buildPostKnowledge(post);
const { Content, headings } = await render(post);
const tableOfContents = headings.filter(
  (heading) => heading.depth === 2 || heading.depth === 3
);
const formattedDate = new Intl.DateTimeFormat("zh-CN", {
  year: "numeric",
  month: "2-digit",
  day: "2-digit"
}).format(post.data.date);
const formattedScripture = post.data.scripture
  .trim()
  .replace(/[：﹕]/g, ":")
  .replace(/[－–—]/g, "-")
  .replace(/\s*:\s*/g, ":")
  .replace(/\s*-\s*/g, "-")
  .replace(/\s+/g, " ");
const categoryRoute = getCategoryRouteByCategory(post.data.category);
const fallbackReturnUrl = `${categoryRoute?.path ?? "/posts/"}#post-${post.slug}`;
---

<BaseLayout
  title={`${post.data.title} | Ronnie`}
  description={knowledge.description}
  type="article"
  publishedTime={post.data.date}
  author={post.data.author || "Ronnie"}
  keywords={[post.data.category, post.data.scripture, ...post.data.tags, ...knowledge.bibleBooks, ...knowledge.topics].filter(Boolean)}
>
  <div class="reading-progress" aria-hidden="true"><span data-reading-progress></span></div>
  <article class="article-page">
    <a
      class="text-link"
      href={fallbackReturnUrl}
      data-return-to-post={post.slug}
    >
      返回文章列表
    </a>
    <header class="article-header">
      <p class="eyebrow article-meta-line">
        <time datetime={post.data.date.toISOString()}>{formattedDate}</time>
        <span class="meta-text">阅读 {knowledge.readingTimeMinutes} 分钟</span>
      </p>
      <h1>{post.data.title}</h1>
      {formattedScripture && <p class="article-scripture">{formattedScripture}</p>}
      <div class="article-stats" aria-label="文章阅读和留言次数">
        <span>阅读 <strong data-post-views={post.slug} data-increment-view>--</strong> 次</span>
        <span>留言 <strong data-post-comments={post.slug}>--</strong> 条</span>
      </div>
      <p>{post.data.description}</p>
      <div class="tag-list">
        {post.data.tags.map((tag) => <span>{tag}</span>)}
      </div>
    </header>
    {
      tableOfContents.length > 0 && (
        <nav class="article-toc" aria-label="文章目录">
          <p>文章目录</p>
          <ol>
            {tableOfContents.map((heading) => (
              <li class:list={[heading.depth === 3 && "nested"]}>
                <a href={`#${heading.slug}`}>{heading.text}</a>
              </li>
            ))}
          </ol>
        </nav>
      )
    }
    <div class="article-content">
      <Content />
    </div>
    {
      relatedPosts.length > 0 && (
        <section class="related-posts" aria-labelledby="related-posts-title">
          <p class="eyebrow">继续阅读</p>
          <h2 id="related-posts-title">相关文章</h2>
          <div>
            {relatedPosts.map((relatedPost) => (
              <a href={`/posts/${relatedPost.slug}/`}>
                <span>{relatedPost.data.category}</span>
                <strong>{relatedPost.data.title}</strong>
              </a>
            ))}
          </div>
        </section>
      )
    }
    {
      (previousPost || nextPost) && (
        <nav class="article-adjacent" aria-label="上一篇和下一篇">
          {previousPost ? (
            <a href={`/posts/${previousPost.slug}/`}>
              <span>上一篇</span>
              <strong>{previousPost.data.title}</strong>
            </a>
          ) : (
            <span aria-hidden="true"></span>
          )}
          {nextPost ? (
            <a href={`/posts/${nextPost.slug}/`}>
              <span>下一篇</span>
              <strong>{nextPost.data.title}</strong>
            </a>
          ) : (
            <span aria-hidden="true"></span>
          )}
        </nav>
      )
    }
    <a
      class="text-link article-return-link"
      href={fallbackReturnUrl}
      data-return-to-post={post.slug}
    >
      返回文章列表
    </a>
    <Comments postSlug={post.slug} />
  </article>

  <script>
    const returnLinks = document.querySelectorAll<HTMLAnchorElement>("[data-return-to-post]");
    const postSlug = returnLinks[0]?.dataset.returnToPost;

    if (returnLinks.length && postSlug) {
      try {
        const savedReturnUrl = window.sessionStorage.getItem(`ronniecross-return-${postSlug}`);
        if (savedReturnUrl) {
          const url = new URL(savedReturnUrl);
          if (url.origin === window.location.origin) {
            returnLinks.forEach((link) => {
              link.href = `${url.pathname}${url.search}${url.hash}`;
            });
          }
        }
      } catch {
        // 使用服务端生成的默认文章列表地址。
      }
    }

    const progress = document.querySelector<HTMLElement>("[data-reading-progress]");
    const article = document.querySelector<HTMLElement>(".article-content");
    const updateProgress = () => {
      if (!progress || !article) return;
      const distance = Math.max(article.offsetHeight - window.innerHeight, 1);
      const value = Math.min(
        Math.max((window.scrollY - article.offsetTop) / distance, 0),
        1
      );
      progress.style.transform = `scaleX(${value})`;
    };
    updateProgress();
    window.addEventListener("scroll", updateProgress, { passive: true });
    window.addEventListener("resize", updateProgress);
  </script>
</BaseLayout>
