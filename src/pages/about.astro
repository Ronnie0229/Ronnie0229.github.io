---
import BaseLayout from "../layouts/BaseLayout.astro";
import Logo from "../components/Logo.astro";
import SubscribeForm from "../components/SubscribeForm.astro";
---

<BaseLayout title="关于 | Ronnie" description="网站版权联系说明。">
  <section class="about-page">
    <Logo size="lg" showText={false} class="about-brand-mark" />
    <div class="copyright-notice">
      <p class="copyright-notice-text">
        如果这里的文章侵犯到您的版权，<br />
        请发送 e-mail 至<a href="mailto:soueitetsu@yahoo.co.jp">soueitetsu@yahoo.co.jp</a>，<br />
        我会尽快删除文章。<br />
        或者您对本站有任何修改意见，<br />
        也请随时联系我，我会立刻改进。<br />
        谢谢，以马内利。
      </p>
    </div>
    <p class="visit-counter" data-visit-counter>
      本站累计访问量：<span data-site-visits>统计中…</span>
    </p>
    <SubscribeForm />
  </section>
</BaseLayout>
