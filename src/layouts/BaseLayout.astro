---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Ronnie",
  description = "Ronnie 的个人主页与文章空间"
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <a class="brand" href="/" aria-label="道路，真理，生命 首页">道路，真理，生命</a>
        <nav class="site-nav" aria-label="文章分类导航">
          <a href="/posts/">全部文章</a>
          <a href="/posts/?category=教会讲道">教会讲道</a>
          <a href="/posts/?category=灵命成长">灵命成长</a>
          <a href="/bible/">圣经书卷</a>
          <a href="/about/">关于</a>
        </nav>
      </header>
      <main>
        <slot />
      </main>
      <footer class="site-footer">
        <span>Ronnie</span>
        <span>活出耶稣的样式</span>
      </footer>
    </div>
  </body>
</html>
