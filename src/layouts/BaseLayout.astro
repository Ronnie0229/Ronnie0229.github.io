---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Ronnie",
  description = "Ronnie 的个人主页与文章空间"
} = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="canonical" href={canonicalUrl} />
    <title>{title}</title>
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <a class="brand" href="/" aria-label="道路，真理，生命 首页">道路，真理，生命</a>
        <nav class="site-nav" aria-label="文章分类导航">
          <a href="/posts/">全部文章</a>
          <a href="/posts/?category=教会讲道">教会讲道</a>
          <a href="/posts/?category=灵命成长">灵命成长</a>
          <a href="/bible/">圣经书卷</a>
          <a href="/about/">关于</a>
        </nav>
      </header>
      <main>
        <slot />
      </main>
      <footer class="site-footer">
        <span>Ronnie</span>
        <span>活出耶稣的样式</span>
      </footer>
    </div>
    <script is:inline>
      (() => {
        const storageKey = "ronniecross-visit-counted";
        const localPreview = ["localhost", "127.0.0.1"].includes(window.location.hostname);
        const counterUrl = localPreview
          ? "https://ronniecross.com/api/visits"
          : "/api/visits";
        const counter = document.querySelector("[data-site-visits]");
        let counted = false;

        try {
          counted = window.sessionStorage.getItem(storageKey) === "1";
        } catch {
          counted = false;
        }

        if (counted && !counter) return;

        const requestUrl = counted ? counterUrl : `${counterUrl}?increment=1`;

        fetch(requestUrl, { cache: "no-store" })
          .then((response) => {
            if (!response.ok) throw new Error("Counter request failed");
            return response.json();
          })
          .then((data) => {
            if (!counted) {
              try {
                window.sessionStorage.setItem(storageKey, "1");
              } catch {
                // The counter still works when session storage is unavailable.
              }
            }

            if (counter && Number.isFinite(data.count)) {
              counter.textContent = `${Number(data.count).toLocaleString("zh-CN")} 次`;
            }
          })
          .catch(() => {
            if (counter) counter.textContent = "暂时无法读取";
          });
      })();
    </script>
  </body>
</html>
