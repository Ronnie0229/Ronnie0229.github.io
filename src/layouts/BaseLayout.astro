---
import Logo from "../components/Logo.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import { createSiteGraph } from "../lib/knowledge/schema";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
  publishedTime?: Date;
  author?: string;
  keywords?: string[];
}

const {
  title = "Ronnie",
  description = "Ronnie 的个人主页与文章空间",
  image = "/images/ronniecross-hero-dark.png",
  type = "website",
  publishedTime,
  author = "Ronnie",
  keywords = []
} = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const socialImage = new URL(image, Astro.site);
const siteUrl = new URL("/", Astro.site);
const logoUrl = new URL("/images/ronniecross-logo-512.png", Astro.site);
const searchUrl = `${new URL("/search/", Astro.site)}?q=%7Bsearch_term_string%7D`;
const currentPath = Astro.url.pathname;
const currentCategory = Astro.url.searchParams.get("category") || "";
const navItems = [
  {
    label: "全部文章",
    href: "/posts/",
    active:
      currentPath.startsWith("/posts/") &&
      currentCategory !== "教会讲道" &&
      currentCategory !== "灵命成长"
  },
  {
    label: "教会讲道",
    href: "/posts/?category=教会讲道",
    active: currentPath.startsWith("/posts/") && currentCategory === "教会讲道"
  },
  {
    label: "灵命成长",
    href: "/posts/?category=灵命成长",
    active: currentPath.startsWith("/posts/") && currentCategory === "灵命成长"
  },
  {
    label: "圣经书卷",
    href: "/bible/",
    active: currentPath.startsWith("/bible/")
  },
  {
    label: "站内搜索",
    href: "/search/",
    active: currentPath.startsWith("/search/")
  },
  {
    label: "关于",
    href: "/about/",
    active: currentPath.startsWith("/about/")
  }
];
const structuredData = createSiteGraph({
  siteUrl,
  canonicalUrl,
  logoUrl,
  searchUrl,
  image: socialImage,
  name: "道路，真理，生命",
  alternateName: "RonnieCross",
  description: "把听到的，看到的，学到的，整理成可以安静阅读的文字。",
  title,
  pageDescription: description,
  type,
  publishedTime,
  author,
  keywords
});
const structuredDataJson = JSON.stringify(structuredData).replace(/</g, "\\u003c");
---

<!doctype html>
<html lang="zh-CN" data-theme="dark" data-theme-mode="system">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:site_name" content="道路，真理，生命" />
    <meta property="og:locale" content="zh_CN" />
    {publishedTime && <meta property="article:published_time" content={publishedTime.toISOString()} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <meta name="theme-color" id="theme-color" content="#061625" />
    <meta name="apple-mobile-web-app-status-bar-style" id="apple-status-bar-style" content="black-translucent" />
    <script is:inline>
      (() => {
        const storageKey = "ronniecross-theme";
        let savedTheme = null;

        try {
          const storedTheme = window.localStorage.getItem(storageKey);
          savedTheme = storedTheme === "dark" || storedTheme === "light" ? storedTheme : null;
        } catch {
          savedTheme = null;
        }

        const setThemeColor = (theme) => {
          const themeColor = document.querySelector('meta[name="theme-color"]');
          const appleStatusBar = document.querySelector('meta[name="apple-mobile-web-app-status-bar-style"]');
          themeColor?.setAttribute("content", theme === "dark" ? "#061625" : "#f7f9fc");
          appleStatusBar?.setAttribute("content", theme === "dark" ? "black-translucent" : "default");
        };

        const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        const theme = savedTheme || (prefersDark ? "dark" : "light");
        document.documentElement.dataset.theme = theme;
        document.documentElement.dataset.themeMode = savedTheme ? "manual" : "system";
        setThemeColor(theme);
      })();
    </script>
    <link rel="icon" type="image/jpeg" href="/images/ronniecross-logo-theme-dark.jpg" />
    <link rel="apple-touch-icon" href="/images/ronniecross-logo-theme-dark.jpg" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="alternate" type="application/rss+xml" title="Ronnie 文章订阅" href="/rss.xml" />
    <link rel="stylesheet" href="/styles/global.css" />
    <link rel="canonical" href={canonicalUrl} />
    <script type="application/ld+json" set:html={structuredDataJson}></script>
    <title>{title}</title>
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <a class="brand" href="/" aria-label="道路，真理，生命 首页">
          <Logo size="sm" />
        </a>
        <div class="header-actions">
          <div class="site-menu" id="site-menu" data-site-menu>
            <nav class="site-nav" aria-label="文章分类导航">
              {
                navItems.map((item) => (
                  <a href={item.href} data-nav-link aria-current={item.active ? "page" : undefined}>
                    {item.label}
                  </a>
                ))
              }
            </nav>
          </div>
          <ThemeToggle />
          <button class="menu-toggle" type="button" aria-controls="site-menu" aria-expanded="false" data-menu-toggle>
            <span></span>
            <span></span>
            <span></span>
            <span class="sr-only">打开导航菜单</span>
          </button>
        </div>
      </header>
      <main>
        <slot />
      </main>
      <footer class="site-footer">
        <span>Ronnie</span>
        <span>活出耶稣的样式</span>
      </footer>
    </div>
    <script is:inline>
      (() => {
        const themeToggle = document.querySelector("[data-theme-toggle]");
        const themeLabel = document.querySelector("[data-theme-label]");
        const menuToggle = document.querySelector("[data-menu-toggle]");
        const menu = document.querySelector("[data-site-menu]");
        const media = window.matchMedia("(prefers-color-scheme: dark)");
        const storageKey = "ronniecross-theme";

        const readSavedTheme = () => {
          try {
            const savedTheme = window.localStorage.getItem(storageKey);
            return savedTheme === "dark" || savedTheme === "light" ? savedTheme : null;
          } catch {
            return null;
          }
        };

        const saveTheme = (theme) => {
          try {
            window.localStorage.setItem(storageKey, theme);
          } catch {
            // The page still works if localStorage is unavailable.
          }
        };

        let manualTheme = readSavedTheme();

        const setThemeColor = (theme) => {
          const themeColor = document.querySelector('meta[name="theme-color"]');
          const appleStatusBar = document.querySelector('meta[name="apple-mobile-web-app-status-bar-style"]');
          themeColor?.setAttribute("content", theme === "dark" ? "#061625" : "#f7f9fc");
          appleStatusBar?.setAttribute("content", theme === "dark" ? "black-translucent" : "default");
        };

        const syncThemeButton = (theme) => {
          if (!themeToggle) return;
          const nextTheme = theme === "dark" ? "light" : "dark";
          const label = theme === "dark" ? "切换到浅色模式" : "切换到深色模式";
          themeToggle.setAttribute("aria-label", label);
          themeToggle.setAttribute("title", label);
          themeToggle.dataset.nextTheme = nextTheme;
          if (themeLabel) themeLabel.textContent = label;
        };

        const shouldReloadForMobileThemeChange = () => {
          const isSmallScreen = window.matchMedia("(max-width: 760px)").matches;
          const isIOS = /iPad|iPhone|iPod/.test(window.navigator.userAgent)
            || (window.navigator.platform === "MacIntel" && window.navigator.maxTouchPoints > 1);
          return isSmallScreen && isIOS;
        };

        const applyTheme = (theme, mode = "manual", persist = false) => {
          document.documentElement.dataset.theme = theme;
          document.documentElement.dataset.themeMode = mode;
          setThemeColor(theme);
          syncThemeButton(theme);
          if (persist) saveTheme(theme);
        };

        const applySystemTheme = () => {
          applyTheme(media.matches ? "dark" : "light", "system");
        };

        if (manualTheme) {
          applyTheme(manualTheme, "manual");
        } else {
          applySystemTheme();
        }

        themeToggle?.addEventListener("click", () => {
          const currentTheme = document.documentElement.dataset.theme === "light" ? "light" : "dark";
          manualTheme = currentTheme === "dark" ? "light" : "dark";
          applyTheme(manualTheme, "manual", true);
          if (shouldReloadForMobileThemeChange()) {
            window.setTimeout(() => {
              window.location.reload();
            }, 80);
          }
        });

        media.addEventListener?.("change", () => {
          if (!manualTheme) applySystemTheme();
        });

        menuToggle?.addEventListener("click", () => {
          const open = menuToggle.getAttribute("aria-expanded") === "true";
          menuToggle.setAttribute("aria-expanded", String(!open));
          menu?.classList.toggle("is-open", !open);
        });

        const syncCurrentNav = () => {
          const links = document.querySelectorAll("[data-nav-link]");
          const currentCategory = new URLSearchParams(window.location.search).get("category") || "";
          const currentPath = window.location.pathname;

          links.forEach((link) => {
            const linkUrl = new URL(link.getAttribute("href"), window.location.origin);
            const linkCategory = linkUrl.searchParams.get("category") || "";
            let active = false;

            if (linkUrl.pathname === "/posts/") {
              active = currentPath.startsWith("/posts/") && currentCategory === linkCategory;
            } else {
              active = currentPath.startsWith(linkUrl.pathname);
            }

            if (active) {
              link.setAttribute("aria-current", "page");
            } else {
              link.removeAttribute("aria-current");
            }
          });
        };

        syncCurrentNav();
      })();
    </script>
    <script is:inline>
      (() => {
        const storageKey = "ronniecross-visit-counted";
        const localPreview = ["localhost", "127.0.0.1"].includes(window.location.hostname);
        const counterUrl = localPreview
          ? "https://ronniecross.com/api/visits"
          : "/api/visits";
        const counter = document.querySelector("[data-site-visits]");
        let counted = false;

        try {
          counted = window.sessionStorage.getItem(storageKey) === "1";
        } catch {
          counted = false;
        }

        if (counted && !counter) return;

        const requestUrl = counted ? counterUrl : `${counterUrl}?increment=1`;

        fetch(requestUrl, { cache: "no-store" })
          .then((response) => {
            if (!response.ok) throw new Error("Counter request failed");
            return response.json();
          })
          .then((data) => {
            if (!counted) {
              try {
                window.sessionStorage.setItem(storageKey, "1");
              } catch {
                // The counter still works when session storage is unavailable.
              }
            }

            if (counter && Number.isFinite(data.count)) {
              counter.textContent = `${Number(data.count).toLocaleString("zh-CN")} 次`;
            }
          })
          .catch(() => {
            if (counter) counter.textContent = "暂时无法读取";
          });
      })();
    </script>
    <script is:inline>
      (() => {
        const counters = Array.from(document.querySelectorAll("[data-post-views]"));
        if (!counters.length) return;

        const localPreview = ["localhost", "127.0.0.1"].includes(window.location.hostname);
        const apiUrl = localPreview
          ? "https://ronniecross.com/api/views"
          : "/api/views";
        const formatCount = (value) => Number(value || 0).toLocaleString("zh-CN");
        const setCount = (slug, value) => {
          counters
            .filter((counter) => counter.getAttribute("data-post-views") === slug)
            .forEach((counter) => {
              counter.textContent = formatCount(value);
            });
        };
        const slugs = [
          ...new Set(
            counters
              .map((counter) => counter.getAttribute("data-post-views"))
              .filter(Boolean)
          )
        ];
        const incrementCounter = counters.find((counter) =>
          counter.hasAttribute("data-increment-view")
        );
        const incrementSlug = incrementCounter?.getAttribute("data-post-views");
        let counted = false;

        if (incrementSlug) {
          try {
            counted =
              window.sessionStorage.getItem(`ronniecross-viewed-${incrementSlug}`) === "1";
          } catch {
            counted = false;
          }
        }

        const loadCounts = async () => {
          const batchSize = 50;

          for (let index = 0; index < slugs.length; index += batchSize) {
            const batch = slugs.slice(index, index + batchSize);
            const params = new URLSearchParams();
            batch.forEach((slug) => params.append("slug", slug));

            try {
              const response = await fetch(`${apiUrl}?${params}`, { cache: "no-store" });
              const data = await response.json();
              if (!response.ok) throw new Error("View count request failed");

              Object.entries(data.views || {}).forEach(([slug, value]) => {
                setCount(slug, value);
              });
            } catch {
              // 保留占位符，避免把接口故障误显示成零次阅读。
            }
          }
        };

        const incrementView = async () => {
          if (!incrementSlug || counted) return;

          try {
            const response = await fetch(apiUrl, {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ postSlug: incrementSlug })
            });
            const data = await response.json();
            if (!response.ok) throw new Error("View count update failed");

            setCount(incrementSlug, data.viewCount);

            try {
              window.sessionStorage.setItem(`ronniecross-viewed-${incrementSlug}`, "1");
            } catch {
              // 阅读计数不依赖本地存储才能显示。
            }
          } catch {
            // 保留批量读取到的计数。
          }
        };

        loadCounts().then(incrementView);
      })();
    </script>
    <script is:inline>
      (() => {
        const counters = Array.from(document.querySelectorAll("[data-post-comments]"));
        if (!counters.length) return;

        const localPreview = ["localhost", "127.0.0.1"].includes(window.location.hostname);
        const apiUrl = localPreview
          ? "https://ronniecross.com/api/comments"
          : "/api/comments";
        const formatCount = (value) => Number(value || 0).toLocaleString("zh-CN");
        const slugs = [
          ...new Set(
            counters
              .map((counter) => counter.getAttribute("data-post-comments"))
              .filter(Boolean)
          )
        ];

        const setCount = (slug, value) => {
          counters
            .filter((counter) => counter.getAttribute("data-post-comments") === slug)
            .forEach((counter) => {
              counter.textContent = formatCount(value);
            });
        };

        const loadCounts = async () => {
          const batchSize = 50;

          for (let index = 0; index < slugs.length; index += batchSize) {
            const params = new URLSearchParams({ mode: "counts" });
            slugs.slice(index, index + batchSize).forEach((slug) => params.append("slug", slug));

            try {
              const response = await fetch(`${apiUrl}?${params}`, { cache: "no-store" });
              const data = await response.json();
              if (!response.ok) throw new Error("Comment count request failed");

              Object.entries(data.counts || {}).forEach(([slug, value]) => {
                setCount(slug, value);
              });
            } catch {
              // 保留占位符，避免把接口故障误显示成零条留言。
            }
          }
        };

        loadCounts();
      })();
    </script>
  </body>
</html>
