---

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
}

const {
  title = "Ronnie",
  description = "Ronnie 的个人主页与文章空间",
  image = "/images/quiet-study-hero.png",
  type = "website"
} = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const socialImage = new URL(image, Astro.site);
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <link rel="alternate" type="application/rss+xml" title="Ronnie 文章订阅" href="/rss.xml" />
    <link rel="stylesheet" href="/styles/global.css" />
    <link rel="canonical" href={canonicalUrl} />
    <title>{title}</title>
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <a class="brand" href="/" aria-label="道路，真理，生命 首页">道路，真理，生命</a>
        <nav class="site-nav" aria-label="文章分类导航">
          <a href="/posts/">全部文章</a>
          <a href="/posts/?category=教会讲道">教会讲道</a>
          <a href="/posts/?category=灵命成长">灵命成长</a>
          <a href="/bible/">圣经书卷</a>
          <a href="/search/">站内搜索</a>
          <a href="/about/">关于</a>
        </nav>
      </header>
      <main>
        <slot />
      </main>
      <footer class="site-footer">
        <span>Ronnie</span>
        <span>活出耶稣的样式</span>
      </footer>
    </div>
    <script is:inline>
      (() => {
        const storageKey = "ronniecross-visit-counted";
        const localPreview = ["localhost", "127.0.0.1"].includes(window.location.hostname);
        const counterUrl = localPreview
          ? "https://ronniecross.com/api/visits"
          : "/api/visits";
        const counter = document.querySelector("[data-site-visits]");
        let counted = false;

        try {
          counted = window.sessionStorage.getItem(storageKey) === "1";
        } catch {
          counted = false;
        }

        if (counted && !counter) return;

        const requestUrl = counted ? counterUrl : `${counterUrl}?increment=1`;

        fetch(requestUrl, { cache: "no-store" })
          .then((response) => {
            if (!response.ok) throw new Error("Counter request failed");
            return response.json();
          })
          .then((data) => {
            if (!counted) {
              try {
                window.sessionStorage.setItem(storageKey, "1");
              } catch {
                // The counter still works when session storage is unavailable.
              }
            }

            if (counter && Number.isFinite(data.count)) {
              counter.textContent = `${Number(data.count).toLocaleString("zh-CN")} 次`;
            }
          })
          .catch(() => {
            if (counter) counter.textContent = "暂时无法读取";
          });
      })();
    </script>
    <script is:inline>
      (() => {
        const counters = Array.from(document.querySelectorAll("[data-post-views]"));
        if (!counters.length) return;

        const localPreview = ["localhost", "127.0.0.1"].includes(window.location.hostname);
        const apiUrl = localPreview
          ? "https://ronniecross.com/api/views"
          : "/api/views";
        const formatCount = (value) => Number(value || 0).toLocaleString("zh-CN");
        const setCount = (slug, value) => {
          counters
            .filter((counter) => counter.getAttribute("data-post-views") === slug)
            .forEach((counter) => {
              counter.textContent = formatCount(value);
            });
        };
        const slugs = [
          ...new Set(
            counters
              .map((counter) => counter.getAttribute("data-post-views"))
              .filter(Boolean)
          )
        ];
        const incrementCounter = counters.find((counter) =>
          counter.hasAttribute("data-increment-view")
        );
        const incrementSlug = incrementCounter?.getAttribute("data-post-views");
        let counted = false;

        if (incrementSlug) {
          try {
            counted =
              window.sessionStorage.getItem(`ronniecross-viewed-${incrementSlug}`) === "1";
          } catch {
            counted = false;
          }
        }

        const loadCounts = async () => {
          const batchSize = 50;

          for (let index = 0; index < slugs.length; index += batchSize) {
            const batch = slugs.slice(index, index + batchSize);
            const params = new URLSearchParams();
            batch.forEach((slug) => params.append("slug", slug));

            try {
              const response = await fetch(`${apiUrl}?${params}`, { cache: "no-store" });
              const data = await response.json();
              if (!response.ok) throw new Error("View count request failed");

              Object.entries(data.views || {}).forEach(([slug, value]) => {
                setCount(slug, value);
              });
            } catch {
              // 保留占位符，避免把接口故障误显示成零次阅读。
            }
          }
        };

        const incrementView = async () => {
          if (!incrementSlug || counted) return;

          try {
            const response = await fetch(apiUrl, {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ postSlug: incrementSlug })
            });
            const data = await response.json();
            if (!response.ok) throw new Error("View count update failed");

            setCount(incrementSlug, data.viewCount);

            try {
              window.sessionStorage.setItem(`ronniecross-viewed-${incrementSlug}`, "1");
            } catch {
              // 阅读计数不依赖本地存储才能显示。
            }
          } catch {
            // 保留批量读取到的计数。
          }
        };

        loadCounts().then(incrementView);
      })();
    </script>
    <script is:inline>
      (() => {
        const counters = Array.from(document.querySelectorAll("[data-post-comments]"));
        if (!counters.length) return;

        const localPreview = ["localhost", "127.0.0.1"].includes(window.location.hostname);
        const apiUrl = localPreview
          ? "https://ronniecross.com/api/comments"
          : "/api/comments";
        const formatCount = (value) => Number(value || 0).toLocaleString("zh-CN");
        const slugs = [
          ...new Set(
            counters
              .map((counter) => counter.getAttribute("data-post-comments"))
              .filter(Boolean)
          )
        ];

        const setCount = (slug, value) => {
          counters
            .filter((counter) => counter.getAttribute("data-post-comments") === slug)
            .forEach((counter) => {
              counter.textContent = formatCount(value);
            });
        };

        const loadCounts = async () => {
          const batchSize = 50;

          for (let index = 0; index < slugs.length; index += batchSize) {
            const params = new URLSearchParams({ mode: "counts" });
            slugs.slice(index, index + batchSize).forEach((slug) => params.append("slug", slug));

            try {
              const response = await fetch(`${apiUrl}?${params}`, { cache: "no-store" });
              const data = await response.json();
              if (!response.ok) throw new Error("Comment count request failed");

              Object.entries(data.counts || {}).forEach(([slug, value]) => {
                setCount(slug, value);
              });
            } catch {
              // 保留占位符，避免把接口故障误显示成零条留言。
            }
          }
        };

        loadCounts();
      })();
    </script>
  </body>
</html>
